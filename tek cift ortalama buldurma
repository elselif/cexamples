/* Girilen 10 FARKLI sayidan ciftlerin ve teklerin ortalamasini bulduran program */

#include <iostream>


using namespace std;
int main(){
	int sayi;
	int tekAdet =0,ciftAdet=0;
	double tekToplam=0,ciftToplam=0;
	for(int i=0;i<10;i++)
	{
		cout <<i+1<<". Sayi : " << endl;
		cin>>sayi;
			if(sayi%2==1)
			{
				tekAdet++;
				tekToplam+=sayi;
			}
			else
			{
				ciftAdet++;
				ciftToplam+=sayi;
			}
	}
	cout<<"girilen tek sayilarin ortalamasi : " <<double(tekToplam/tekAdet) << endl;
	cout<<"girilen cift sayilarin ortalamasi : " <<double(ciftToplam/ciftAdet)<<endl;
	
	return 0 ;
	
}
